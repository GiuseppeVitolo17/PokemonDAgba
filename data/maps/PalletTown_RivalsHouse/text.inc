PalletTown_RivalsHouse_Text_HiBrothersAtLab::
    .string "DAISY: Hej, {PLAYER}!\p"
    .string "Min bror, {RIVAL}, er ude ved\n"
    .string "Bedstefars LAB.$"

PalletTown_RivalsHouse_Text_HeardYouBattledRival::
    .string "DAISY: {PLAYER}, jeg hoerte du kaempede\n"
    .string "mod {RIVAL}.\p"
    .string "Jeg ville oenske jeg havde set det!$"

PalletTown_RivalsHouse_Text_ErrandForGrandpaThisWillHelp::
    .string "Bedstefar bad dig om et aerinde?\p"
    .string "Av, det er dovent af ham.\n"
    .string "Her, dette vil hjaelpe dig.$"

PalletTown_RivalsHouse_Text_ReceivedTownMapFromDaisy::
    .string "{PLAYER} modtog et BYKORT\n"
    .string "fra DAISY.$"

PalletTown_RivalsHouse_Text_DontHaveSpaceForThis::
    .string "Du har ikke plads til dette i\n"
    .string "din TASKE.$"

PalletTown_RivalsHouse_Text_ExplainTownMap::
    .string "Du kan bruge BYKORTET til at finde\n"
    .string "ud af hvor du er, eller tjekke\l"
    .string "stedsnavne.$"

PalletTown_RivalsHouse_Text_PleaseGiveMonsRest::
    .string "DAISY: Lige som mennesker er POKeMON\n"
    .string "levende vaesener.\p"
    .string "Naar de bliver traette, giv dem\n"
    .string "venligst hvile.$"

PalletTown_RivalsHouse_Text_ItsBigMapOfKanto::
    .string "Det er et stort kort over KANTO-regionen.\n"
    .string "Det vil vaere nyttigt!$"

PalletTown_RivalsHouse_Text_ShelvesCrammedFullOfBooks::
    .string "Hylderne er proppet med boeger\n"
    .string "om POKeMON.$"

PalletTown_RivalsHouse_Text_LikeMeToGroomMon::
    .string "DAISY: Hej, {PLAYER}!\n"
    .string "God timing.\p"
    .string "Jeg skal lige til at drikke te.\n"
    .string "Vil du vaere med?\p"
    .string "Oh, men se.\n"
    .string "Dine POKeMON er lidt snavsede.\p"
    .string "Skal jeg pudse en?$"

PalletTown_RivalsHouse_Text_DontNeedAnyGrooming::
    .string "Du har ikke brug for pudning?\n"
    .string "Okay, vi tager bare te.$"

PalletTown_RivalsHouse_Text_GroomWhichOne::
    .string "Hvilken skal jeg pudse?$"

PalletTown_RivalsHouse_Text_LookingNiceInNoTime::
    .string "DAISY: Okay, jeg faar den til at se\n"
    .string "paen ud med det samme.$"

PalletTown_RivalsHouse_Text_ThereYouGoAllDone::
#ifdef BUGFIX @ The localizers missed what should be a textcolor change in the localizations.
