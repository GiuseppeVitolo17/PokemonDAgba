FiveIsland_WaterLabyrinth_Text_GladIMetSomeoneLikeYou::
    .string "Jeg modtog det AeG mens jeg\n"
    .string "rejste.\p"
    .string "Jeg er glad for at jeg moedte en\n"
    .string "som dig.$"

FiveIsland_WaterLabyrinth_Text_CuteMonRemindsMeOfDaisy::
    .string "Oeh, hej.\n"
    .string "Det er en soed {STR_VAR_2}.\p"
    .string "At se den minder mig om en sod\n"
    .string "lille pige jeg moedte paa rejse.\p"
    .string "Hun plejede POKeMON blidt...\n"
    .string "Hun var en lille engel.\p"
    .string "Den lille piges navn…\n"
    .string "Jeg tror det var DAISY.$"

FiveIsland_WaterLabyrinth_Text_AlizeIntro::
    .string "Dette er et fremragende miljoe\n"
    .string "til at opdrage POKeMON.$"

FiveIsland_WaterLabyrinth_Text_AlizeDefeat::
    .string "Dine POKeMON vokser beundringsvaerdigt!$"

FiveIsland_WaterLabyrinth_Text_AlizePostBattle::
    .string "Du ved, jeg tror du har talent\n"
    .string "til at vaere en god AVLER.$"

