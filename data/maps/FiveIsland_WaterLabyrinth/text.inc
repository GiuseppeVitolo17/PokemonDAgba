FiveIsland_WaterLabyrinth_Text_LetMeTakeLookAtMons::
    .string "Du rejser overalt,\n"
    .string "goer du ikke?\p"
    .string "Du koerer ikke dine POKeMON for\n"
    .string "haardt, vel?\p"
    .string "Lad mig se.\n"
    .string "… … …   … … …$"

FiveIsland_WaterLabyrinth_Text_HmmISeeIsee::
    .string "Ah, hmm…\n"
    .string "Jeg ser, jeg ser…$"

FiveIsland_WaterLabyrinth_Text_TreatMonRightHaveThis::
    .string "Oeh, imponerende.\n"
    .string "Du behandler dine POKeMON rigtigt.\p"
    .string "Jeg tror du kan betros med dette.\p"
    .string "Vaersgo, jeg vil gerne give dig dette.$"

FiveIsland_WaterLabyrinth_Text_ReceivedEggFromMan::
    .string "{PLAYER} modtog et AeG\n"
    .string "fra manden!$"

FiveIsland_WaterLabyrinth_Text_DontHaveSpaceInYourParty::
    .string "…Desvaerre har du ikke plads til\n"
    .string "dette i dit hold.\p"
    .string "Du boer komme tilbage efter det\n"
    .string "en anden gang.$"

