Route15_Text_RouteSign::
    .string "ROUTE 15\n"
    .string "Vest til FUCHSIA CITY$"

Route15_Text_MyaIntro::
    .string "MYA: Du er perfekt.\n"
    .string "Hjælp mig med at træne min lillebror?$"

Route15_Text_MyaDefeat::
