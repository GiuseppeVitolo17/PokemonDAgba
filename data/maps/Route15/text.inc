Route15_Text_OliviaPostBattle::
    .string "Jeg elsker at mine POKéMON hilser\n"
    .string "mig nâr jeg kommer hjem.\p"
    .string "Det er sâ betryggende.$"

Route15_Text_ErnestIntro::
