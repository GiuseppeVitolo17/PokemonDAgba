    .string "Ah, saa du vil udfordre\n"
    .string "ELITE FOUR?$"

VictoryRoad_2F_Text_NelsonDefeat::
    .string "Du fik mig!$"

VictoryRoad_2F_Text_NelsonPostBattle::
