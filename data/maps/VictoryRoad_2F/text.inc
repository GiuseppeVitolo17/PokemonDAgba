VictoryRoad_2F_Text_DawsonIntro::
    .string "Hvis du kan komme igennem her,\n"
    .string "kan du moede ELITE FOUR.$"

VictoryRoad_2F_Text_DawsonDefeat::
    .string "Nej!\n"
    .string "Utroligt!$"

VictoryRoad_2F_Text_DawsonPostBattle::
    .string "Jeg kan slaa dig naar det gaelder\n"
    .string "viden om POKeMON!$"

VictoryRoad_2F_Text_DaisukeIntro::
    .string "Dette er VICTORY ROAD.\n"
    .string "Det er den endelige proeve for TRAeNERE!$"

VictoryRoad_2F_Text_DaisukeDefeat::
