PokemonLeague_ChampionsRoom_Text_Defeat::
    .string "NEJ!\n"
    .string "Det kan ikke vaere!\l"
    .string "Du besejrede mig paa mit bedste!\p"
    .string "Efter alt det arbejde for at blive\n"
    .string "LEAGUE MESTER?\p"
    .string "Min regeringstid er allerede forbi?\n"
    .string "Det er ikke fair!$"

PokemonLeague_ChampionsRoom_Text_Victory::
    .string "はーはッ！\n"
    .string "かった！　かった！　かった！\p"
    .string "{PLAYER}に　まける　ような\n"
    .string "おれさま　では　なーい！\p"
    .string "ま！　ポケモンの\n"
    .string "てんさい　{RIVAL}さま　あいてに\l"
    .string "ここまで　よく　がんばった！\p"
    .string "ほめて　つかわす！\n"
    .string "はーッ！　はーはッはッ！$"

PokemonLeague_ChampionsRoom_Text_PostBattle::
    .string "Hvorfor?\n"
    .string "Hvorfor tabte jeg?\p"
    .string "Jeg lavede aldrig fejl da jeg\n"
    .string "opdrog mine POKeMON…\p"
    .string "Pokkers! Du er den nye POKeMON\n"
    .string "LEAGUE MESTER!\p"
    .string "Selvom jeg ikke vil indroemme det…$"

PokemonLeague_ChampionsRoom_Text_OakPlayer::
    .string "OAK: {PLAYER}!$"

PokemonLeague_ChampionsRoom_Text_OakCongratulations::
    .string "OAK: Saa du vandt!\n"
    .string "Oprigtige tillykke!\p"
    .string "Du er den nye POKeMON LEAGUE\n"
    .string "MESTER!\p"
    .string "Du er vokset saa meget siden du\n"
    .string "foerst tog afsted med {STR_VAR_1} for at\l"
    .string "arbejde paa POKeDEX.\p"
    .string "{PLAYER}, du er blevet voksen!$"

PokemonLeague_ChampionsRoom_Text_OakImDisappointedRival::
    .string "OAK: {RIVAL}…\n"
    .string "Jeg er skuffet over dig.\p"
    .string "Jeg kom da jeg hoerte du havde besejret\n"
    .string "ELITE FOUR.\p"
    .string "Men da jeg kom her, havde du\n"
    .string "allerede tabt!\p"
    .string "{RIVAL}, forstaar du hvorfor\n"
    .string "du tabte?\p"
    .string "Du har glemt at behandle dine\n"
    .string "POKeMON med kaerlighed og tillid.\p"
    .string "Uden dem bliver du aldrig\n"
    .string "MESTER igen!$"

PokemonLeague_ChampionsRoom_Text_OakPlayerComeWithMe::
    .string "OAK: {PLAYER}.\p"
    .string "Du forstaar at din sejr\n"
    .string "ikke bare var din egen.\p"
    .string "Baandet du deler med dine\n"
    .string "POKeMON er vidunderligt.\p"
    .string "{PLAYER}!\n"
    .string "Kom med mig!$"
