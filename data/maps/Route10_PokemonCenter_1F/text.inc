Route10_PokemonCenter_1F_Text_EveryTypeStrongerThanOthers::
    .string "POKéMON-typerne matcher forskelligt\n"
    .string "med hinanden.\p"
    .string "Hver type er stærkere end nogle\n"
    .string "typer og svagere end andre.$"

Route10_PokemonCenter_1F_Text_NuggetUselessSoldFor5000::
    .string "En NUGGET er totalt ubrugelig.\n"
    .string "Sâ jeg solgte den for ¥5000.$"

Route10_PokemonCenter_1F_Text_HeardGhostsHauntLavender::
